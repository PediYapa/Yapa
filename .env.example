# ============================================================================
# Yapa — variáveis de ambiente. Copie para .env.local e preencha.
# NUNCA commitar .env.local (já está no .gitignore).
# ============================================================================

# Supabase (banco + auth). Criar projeto em https://supabase.com (login via GitHub).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Z-API (WhatsApp — não-oficial). Painel: https://app.z-api.io
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# DLocal (pagamentos multi-moeda GS/Pix). https://dlocal.com
DLOCAL_API_BASE=
DLOCAL_API_KEY=
DLOCAL_SECRET=
DLOCAL_WEBHOOK_SECRET=

# OpenAI (agente conversacional de pedidos). https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Câmbio (conversão Pix → Guarani). Taxa padrão usada quando a API não está configurada.
CAMBIO_BRL_GS=1450
